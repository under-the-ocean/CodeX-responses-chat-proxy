# Upstream Chat Completions compatible endpoint.
# If the upstream exposes /v1/chat/completions, set the base URL to include /v1.
UPSTREAM_BASE_URL=https://api.openai.com/v1
UPSTREAM_API_KEY=sk-your-upstream-key

# Optional client-facing API key. Leave empty to disable proxy-side auth.
PROXY_API_KEY=

# Server and upstream options.
HOST=0.0.0.0
PORT=8000
REQUEST_TIMEOUT_SECONDS=120
STREAM_TIMEOUT_SECONDS=300
VERIFY_SSL=true

# Logging options.
# LOG_LEVEL: debug, info, warning, error (default: info)
LOG_LEVEL=info

# LOG_REQUESTS: Set to true to log full request bodies (may contain sensitive data)
LOG_REQUESTS=false

# LOG_RESPONSES: Set to true to log full response bodies
LOG_RESPONSES=false

# Model mapping: Map client-side model names to upstream model names.
# Format: JSON object with client model as key and upstream model as value.
# Example: Map all GPT models to deepseek-v4-flash
MODEL_MAPPING={"gpt-4o":"deepseek-v4-flash","gpt-4o-mini":"deepseek-v4-flash","gpt-4-turbo":"deepseek-v4-flash","gpt-4":"deepseek-v4-flash","gpt-4-32k":"deepseek-v4-flash","gpt-3.5-turbo":"deepseek-v4-flash","gpt-3.5-turbo-16k":"deepseek-v4-flash","gpt-3.5":"deepseek-v4-flash","gpt-5.5":"deepseek-v4-flash","gpt-5.4":"deepseek-v4-flash","gpt-5.4-mini":"deepseek-v4-flash","gpt-5.3-codex":"deepseek-v4-flash","gpt-5.2":"deepseek-v4-flash"}
